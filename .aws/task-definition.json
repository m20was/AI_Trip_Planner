{
  "family": "trip-planner-task",
  "executionRoleArn": "arn:aws:iam::566167302601:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "trip-planner-container",
      "image": "will-be-replaced-by-github-actions",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8501,
          "hostPort": 8501,
          "protocol": "tcp"
        },
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/trip-planner-task",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:OPENAI_API_KEY::"
        },
        {
          "name": "GROQ_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:GROQ_API_KEY::"
        },
        {
          "name": "GOOGLE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:GOOGLE_API_KEY::"
        },
        {
          "name": "GPLACES_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:GPLACES_API_KEY::"
        },
        {
          "name": "FOURSQUARE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:FOURSQUARE_API_KEY::"
        },
        {
          "name": "TAVILAY_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:TAVILAY_API_KEY::"
        },
        {
          "name": "TAVILY_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:TAVILAY_API_KEY::"
        },
        {
          "name": "OPENWEATHERMAP_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:OPENWEATHERMAP_API_KEY::"
        },
        {
          "name": "EXCHANGE_RATE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:EXCHANGE_RATE_API_KEY::"
        },
        {
          "name": "LANGCHAIN_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:LANGCHAIN_API_KEY::"
        },
        {
          "name": "LANGCHAIN_TRACING_V2",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:566167302601:secret:trip-planner-secrets-kOFhkV:LANGCHAIN_TRACING_V2::"
        }
      ]
    }
  ]
}
